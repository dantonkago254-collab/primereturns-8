# Copy this file to .env and fill in the values (do NOT commit .env to Git)

# PrimeReturns — Railway deployment variables
NODE_ENV=production
PORT=3000
APP_URL=https://primereturns.up.railway.app

# MySQL (Railway MySQL add-on → copy from the "Connect" tab)
DATABASE_URL=mysql://root:your-password@your-host:3306/railway
MYSQL_CONNECTION_LIMIT=10
CRON_BATCH_SIZE=500

# Authentication
JWT_SECRET=replace_me_with_a_long_random_string_use_openssl_rand_hex_32

# First admin account. The server creates or updates this user on startup.
ADMIN_NAME=PrimeReturns Admin
ADMIN_EMAIL=admin@primereturns.co.ke
ADMIN_PASSWORD=replace_me_with_a_strong_password

# Super admin can perform audited manual balance adjustments. Keep this private.
SUPER_ADMIN_NAME=PrimeReturns Owner
SUPER_ADMIN_EMAIL=superadmin@primereturns.co.ke
SUPER_ADMIN_PASSWORD=replace_me_with_a_very_strong_password

# Paystack — https://dashboard.paystack.com/#/settings/developer
# Keep PAYSTACK_SECRET_KEY server-side ONLY — never expose to the browser.
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here

# Google Sign-In — Google Cloud Console OAuth Web Client ID
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# GitHub Sign-In — GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# SMTP email for password recovery. HostPinnacle/cPanel email works here.
SMTP_HOST=mail.your-domain.co.ke
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@your-domain.co.ke
SMTP_PASS=your_email_password
SMTP_FROM="PrimeReturns <support@your-domain.co.ke>"

# For local/staging only. Do not enable in production unless you understand the risk.
ALLOW_RESET_LINK_RESPONSE=false

# Cron — random string to protect /api/cron/daily-returns
CRON_SECRET=replace_me_with_another_long_random_string
