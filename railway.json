{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"]
    },
    "buildCommand": "npm run build",
    "startCommand": "node server.cjs"
  },
  "deploy": {
    "startCommand": "node server.cjs",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30000
  }
}
